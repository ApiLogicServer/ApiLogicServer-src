    transaction_nbr INTEGER 
    ci_image_tmstp DATETIME 
    iid_master_cd VARCHAR(4) 
    iid_classify_cd VARCHAR(8) 
    automation_ci_flg VARCHAR(1) 
    iid_flg VARCHAR(1) 
    carriage_value_amt DECIMAL 
    customs_value_amt DECIMAL 
    dest_customs_value_amt DECIMAL 
    local_customs_value_amt DECIMAL 
    active_flg VARCHAR(1) 
    entry_dt DATE 
    admissibility_mode VARCHAR(1) 
    prev_admissibility_mode VARCHAR(1) 
    cargocontrolnbr VARCHAR(22) 
    portofexit VARCHAR(6) 
    portofentry VARCHAR(6) 
    warehousecode VARCHAR(6) 
    surface_intl_shipment_nbr NUMERIC 
