    local_customs_currency_cd VARCHAR(3) 
    manuf_orig_cntry_cd VARCHAR(2) 
    manifest_status_cd VARCHAR(2) 
    mde_source_cd VARCHAR(1) 
    meter_nbr INTEGER 
    oda_charge_flg VARCHAR(1) 
    opa_charge_flg VARCHAR(1) 
    origin_loc_city_nm VARCHAR(35) 
    origin_loc_cntry_cd VARCHAR(2) 
    origin_eec_flg VARCHAR(1) 
    origin_location_cd VARCHAR(5) 
    package_movement_scan_cd VARCHAR(1) 
    packaging_type_cd VARCHAR(3) 
    piece_qty INTEGER 
    pkg_mark_desc VARCHAR(35) 
    prior_notice_nbr VARCHAR(30) 
    ramp_transfer_flg VARCHAR(1) 
    record_status_cd VARCHAR(1) 
    rod_flg VARCHAR(1) 
    rpl_flg VARCHAR(1) 
    sdl_flg VARCHAR(1) 
    sed_cd VARCHAR(1) 
    sed_exempt_nbr VARCHAR(2) 
    service_cd VARCHAR(5) 
    service_type_cd VARCHAR(2) 
    shipment_control_nbr VARCHAR(25) 
    ship_dt DATE 
    shipment_desc VARCHAR(200) 
    shipment_id_nbr INTEGER 
    shipper_reference_desc VARCHAR(35) 
    split_billing_address_amt DECIMAL 
    split_billing_kilo_wgt DECIMAL 
    spu_flg VARCHAR(1) 
    total_wgt DECIMAL 
    total_wgt_uom_cd VARCHAR(3) 
    tracking_id_nbr VARCHAR(20) 
    tracking_id_qual_nbr VARCHAR(30) 
    transaction_seq_tmstp DATETIME 
    trprt_bill_to_acct_nbr INTEGER 
    trprt_bill_to_cd VARCHAR(1) 
    trprt_credit_card_flg VARCHAR(1) 
    tran_data_source_cd VARCHAR(2) 
    unassign_reason_cd VARCHAR(4) 
    unloading_usa_port_cd VARCHAR(5) 
    value_changed_flg VARCHAR(1) 
    weekday_delivery_flg VARCHAR(1) 
    xtn_nbr VARCHAR(32) 
    dest_loc_city_nm VARCHAR(35) 
    final_import_clearance_loc_cd VARCHAR(5) 
    image_folder_id_cd VARCHAR(20) 
    aci_download_flg VARCHAR(1) 
    broker_dest_loc_cd VARCHAR(5) 
    visa_trans_cd VARCHAR(2) 
    etl_tmstp DATETIME 
    split_shipment_flg VARCHAR(1) 
