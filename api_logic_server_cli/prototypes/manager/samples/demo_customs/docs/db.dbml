    entry_category_type_cd VARCHAR(3) 
    eci_flg VARCHAR(1) 
    ci_image_flg VARCHAR(1) 
    trprt_bill_to_pymt_method_cd INTEGER 
    duplicate_shipment_record_flg VARCHAR(1) 
    oga_shipment_flg VARCHAR(1) 
