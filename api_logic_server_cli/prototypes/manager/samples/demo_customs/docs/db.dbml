    dim_width_qty INTEGER 
    dim_shipment_flg VARCHAR(1) 
    discharge_location_cd VARCHAR(4) 
    drop_dscnt_cd VARCHAR(1) 
    dutiable_flg VARCHAR(1) 
    duty_bill_to_acct_nbr INTEGER 
    duty_bill_to_cd VARCHAR(1) 
    duty_cash_flg VARCHAR(1) 
    duty_credit_card_flg VARCHAR(1) 
    ecs_filing_status_cd VARCHAR(1) 
    export_country_cd VARCHAR(2) 
    export_license_flg VARCHAR(1) 
    fda_confirmation_flg VARCHAR(1) 
    carrier_assigned_mawb_nbr VARCHAR(12) 
    planned_clearance_location_cd VARCHAR(5) 
    form_type_cd VARCHAR(4) 
    free_domicile_cd VARCHAR(1) 
    freight_charge_amt DECIMAL 
    ftsr_nbr INTEGER 
    goods_class_cd VARCHAR(2) 
    hal_flg VARCHAR(1) 
    hal_phone_nbr VARCHAR(20) 
