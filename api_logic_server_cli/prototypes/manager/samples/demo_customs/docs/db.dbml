Table CcpCustomer {
    id INTEGER [primary key]
    name VARCHAR(50) 
    address1 VARCHAR(50) 
    address2 VARCHAR(50) 
    city VARCHAR(30) 
    state VARCHAR(10) 
    country VARCHAR(3) 
    postal VARCHAR(15) 
    business_nbr VARCHAR(20) 
    gst_reg VARCHAR(20) 
    duty_bill_to_acct_nbr INTEGER 
    duty_bill_to_cd VARCHAR(1) 
    payor_location VARCHAR(5) 
    weight VARCHAR(10) 
    export_country VARCHAR(3) 
    foreign_trade_zone VARCHAR(5) 
    discounts VARCHAR(10) 
    last_modified_nm VARCHAR(20) 
    data_form VARCHAR(10) 
    customeroid INTEGER 
    profile_ref_nbr INTEGER 
    dpi VARCHAR(1) 
    po_box VARCHAR(1) 
    phone_nbr VARCHAR(20) 
    broker_cd VARCHAR(5) 
    rod VARCHAR(1) 
    }

Table Piece {
    local_piece_oid_nbr INTEGER [primary key]
    local_shipment_oid_nbr INTEGER 
    arrival_port_cd VARCHAR(5) 
    awb_type_cd VARCHAR(1) 
    awb_format_cd VARCHAR(1) 
    contract_wgt_type_cd VARCHAR(1) 
    customs_value_amt DECIMAL 
    decln_oid_nbr INTEGER 
    decln_status_cd VARCHAR(1) 
    dest_location_cd VARCHAR(5) 
    dim_wgt DECIMAL 
    final_dest_cd VARCHAR(5) 
    form_type_cd VARCHAR(4) 
    harmonized_tariff_nbr VARCHAR(20) 
    ipd_doc_nbr VARCHAR(12) 
    last_foreign_port_cd VARCHAR(5) 
    last_modified_location_cd VARCHAR(5) 
    last_modified_nm VARCHAR(35) 
    manifest_status_cd VARCHAR(2) 
    manifest_tmstp DATETIME 
    payment_option_cd VARCHAR(1) 
    payor_account_nbr INTEGER 
    payor_account_type_cd VARCHAR(1) 
    piece_qty INTEGER 
    piece_status_cd VARCHAR(1) 
    piece_type_cd VARCHAR(1) 
    port_of_export_cd VARCHAR(5) 
    port_of_unlading_cd VARCHAR(5) 
    rih_clearance_loc_cd VARCHAR(5) 
    shipper_reference_desc VARCHAR(35) 
    split_billing_business_cd VARCHAR(12) 
    split_billing_address_amt DECIMAL 
    split_billing_kilo_wgt DECIMAL 
    split_billing_currency_cd VARCHAR(3) 
    total_wgt DECIMAL 
    total_wgt_uom_cd VARCHAR(3) 
    tracking_nbr VARCHAR(12) 
    transaction_seq_tmstp DATETIME 
    variable_pct INTEGER 
    xref_nbr VARCHAR(12) 
    etl_tmstp DATETIME 
    shipment_type_cd INTEGER 
    split_seq_nbr INTEGER 
    piece_deleted_flg VARCHAR(1) 
    piece_seq_nbr INTEGER 
    piece_movement_flg VARCHAR(1) 
    }

Table Shipment {
    local_shipment_oid_nbr INTEGER [primary key]
    awb_nbr VARCHAR(20) 
    base_charge_amt DECIMAL 
    cargo_desc VARCHAR(45) 
    cargo_qty INTEGER 
    cash_in_advance_flg VARCHAR(1) 
    ci_seq_nbr VARCHAR(1) 
    comat_flg VARCHAR(1) 
    consolidated_freight_flg VARCHAR(1) 
    container_nbr VARCHAR(10) 
    contract_wgt_type_cd VARCHAR(1) 
    create_dt DATE 
    csa_flg VARCHAR(1) 
    customer_seq_nbr INTEGER 
    customs_clearance_cd VARCHAR(1) 
    customs_clearance_entry_flg VARCHAR(1) 
    dang_goods_cd VARCHAR(1) 
    data_entry_location_cd VARCHAR(5) 
    deleted_flg VARCHAR(1) 
    dest_customs_currency_cd VARCHAR(3) 
    dest_eec_flg VARCHAR(1) 
    dest_location_cd VARCHAR(5) 
    dest_loc_cntry_cd VARCHAR(2) 
    dim_height_qty INTEGER 
    dim_length_qty INTEGER 
